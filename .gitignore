# ============================================================
#  Business Analytics Agent — .gitignore
# ============================================================

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.python-version

# ---- Build / dist ----
node_modules/
build/
dist/
frontend/dist/
# The Flask app serves Vite output directly from static/dist in source builds.
# Keep generated runtime assets trackable so GitHub users do not load a 404 shell.
static/dist/*
!static/dist/
!static/dist/*.js
!static/dist/*.css
!static/dist/chunks/
!static/dist/chunks/**
!static/dist/assets/
!static/dist/assets/**
!static/dist/.vite/
!static/dist/.vite/**
*.spec
!packaging/business_agent.spec
*.egg-info/
.eggs/

# ---- Runtime / cache ----
.deps_installed
.session_tmps/
outputs/
tmp/
uploads/
*.log
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---- Local-only tests ----
# Keep the tests already tracked by Git for GitHub Actions, but do not add
# newly created local tests to the repository.
Test/*
!Test/test_workflow_contracts.py
!Test/test_workflows.py
!Test/test_workflow_scheduler.py
!Test/test_job_terminal_listeners.py
!Test/test_workflow_runtime.py
!Test/test_workspace_storage_workflow_refs.py
!Test/test_workflow_frontend_panel.py
!Test/test_workflow_sqlite_locking.py
!Test/fixtures/
!Test/fixtures/workflows/
!Test/fixtures/workflows/operating_analysis_v1.json
Test/local_*.py
Test/test_workspace_storage_cleanup.py

# Keep all development tests local.
Test/

# ---- IDE / editor ----
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
.workbuddy

# ---- OS ----
desktop.ini

# ---- Local secrets / config ----
.env
.env.local
*.local
LLM/llm_config.json
LLM/mcp_config.json
LLM/embedding_config.json
data/datasource_config.json
.playwright-mcp
docs/*
!docs/10-ai-team-workflow-optimization-plan.md
!docs/11-ai-team-workflow-wf0-decisions.md
test.bat
01-notes-for-development.md


# ---- Large assets that should not be tracked ----
*.psd
!Banner.psd

# ---- Ongoingwork ----
MCP/Flowchart
MCP/mindmap
MCP/playwright
MCP/flowchart_server.py
LLM/llm_config.json
LLM/llm_config.json
RAILWAY_DEPLOY.md
.prettierignore
.prettierrc.json
config/hooks.json
frontend/README.md
package-lock.json
.claude
