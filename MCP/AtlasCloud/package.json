{
  "name": "atlascloud-mcp",
  "version": "1.3.0",
  "description": "MCP server for Atlas Cloud - AI API aggregation platform for image/video generation and LLM",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "atlascloud-mcp": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "atlascloud",
    "ai",
    "llm",
    "image-generation",
    "video-generation",
    "model-context-protocol"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "undici": "^7.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
